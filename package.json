{
    "name": "core-maugli",
    "description": "Astro & Tailwind CSS blog theme for Maugli.",
    "type": "module",
    "version": "1.1.0",
    "license": "GPL-3.0-or-later OR Commercial",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dashapps/maugli-astro-theme.git"
    },
    "author": "Maugli Content Farm",
    "keywords": [
        "astro",
        "blog",
        "astroblog",
        "maugli",
        "theme",
        "tailwindcss"
    ],
    "scripts": {
        "typograf": "node typograf-batch.js",
        "dev": "astro dev",
        "start": "astro dev",
        "build": "node typograf-batch.js && node scripts/verify-assets.js && astro build",
        "test": "node tests/examplesFilter.test.ts",
        "astro": "astro",
        "featured:add": "node scripts/featured.js add",
        "featured:remove": "node scripts/featured.js remove",
        "featured:list": "node scripts/featured.js list",
        "upgrade": "node scripts/upgrade-config.js",
        "backup-update": "node scripts/update-with-backup.js",
        "postinstall": "node scripts/upgrade-config.js"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.3",
        "@astrojs/mdx": "^3.1.7",
        "@astrojs/rss": "^4.0.7",
        "@astrojs/sitemap": "^3.1.6",
        "@astrojs/tailwind": "^5.1.0",
        "@fontsource/inter": "^5.0.20",
        "@tailwindcss/typography": "^0.5.15",
        "astro": "^4.15.4",
        "clsx": "^2.1.1",
        "fuse.js": "^7.0.0",
        "reading-time": "^1.5.0",
        "slugify": "^1.6.6",
        "tailwindcss": "^3.4.10",
        "typescript": "^5.5.4",
        "prompts": "^2.4.2"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.16",
        "prettier": "^3.5.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "vite-imagetools": "^7.1.0",
        "vite-plugin-pwa": "^1.0.0"
    },
    "files": [
        "src",
        "public",
        "scripts",
        "typograf-batch.js",
        "resize-all.cjs",
        "bin",
        "astro.config.mjs",
        "tsconfig.json",
        "vite.config.js",
        "LICENSE",
        "README.md"
    ],
    "main": "bin/index.js",
    "bin": {
        "core-maugli": "bin/index.js"
    }
}
